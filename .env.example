# =============================================================================
# 校园帮 · 环境变量配置文件
# 使用说明：
# 1. 复制此文件为 .env（git 已忽略，不会提交到版本控制）
# 2. 根据实际情况修改下面的配置值
# 3. Spring Boot 会自动加载 .env 文件中的变量
# =============================================================================

# -----------------------------------------------------------------------------
# 服务器配置
# -----------------------------------------------------------------------------
SERVER_PORT=8080
GATEWAY_PORT=8081
USER_SERVICE_PORT=8082
ORDER_SERVICE_PORT=8083
PRODUCT_SERVICE_PORT=8084
LIFE_SERVICE_PORT=8085
SEARCH_INDEXER_PORT=8091
SPRING_PROFILES_ACTIVE=dev

# -----------------------------------------------------------------------------
# 服务发现（Nacos，可选）
# -----------------------------------------------------------------------------
NACOS_ENABLED=false
NACOS_SERVER_ADDR=127.0.0.1:8848

# -----------------------------------------------------------------------------
# 数据库配置（MySQL）
# -----------------------------------------------------------------------------
DB_URL=jdbc:mysql://localhost:3306/campus_help?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=233615

# -----------------------------------------------------------------------------
# Redis 配置
# -----------------------------------------------------------------------------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# 如果 Redis 没有密码，留空或注释掉此行
# REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# -----------------------------------------------------------------------------
# RabbitMQ 配置
# -----------------------------------------------------------------------------
SPRING_RABBITMQ_HOST=127.0.0.1
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=guest
SPRING_RABBITMQ_PASSWORD=guest
SPRING_RABBITMQ_VIRTUAL_HOST=/

# -----------------------------------------------------------------------------
# JWT 配置
# -----------------------------------------------------------------------------
# 生产环境请使用至少 64 字符的强随机字符串
JWT_SECRET=campus-help-jwt-dev-only-change-in-prod-use-env-JWT_SECRET-64chars-minimum-for-hs512!!
JWT_EXPIRATION_MS=86400000

# -----------------------------------------------------------------------------
# 阿里云 OSS 配置（可选，不使用则保持 enabled=false）
# -----------------------------------------------------------------------------
OSS_ENABLED=false
OSS_ENDPOINT=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_PREFIX=campus-help/dev/
OSS_PRESIGN_EXPIRE_SECONDS=600
OSS_PUBLIC_BASE_URL=

# -----------------------------------------------------------------------------
# 业务配置
# -----------------------------------------------------------------------------
# 支付模拟密钥（开发测试用）
CAMPUS_PAYMENT_MOCK_SECRET=

# 商户注册邀请码
CAMPUS_AUTH_MERCHANT_INVITE=

# 订单支付超时时间（分钟）
ORDER_PAY_TIMEOUT_MINUTES=15

# 订单过期扫描间隔（毫秒）
ORDER_EXPIRE_SCAN_MS=30000

# 秒杀功能开关
CAMPUS_SECKILL_ENABLED=false

# 消息队列延迟订单开关
CAMPUS_MQ_ORDER_DELAY_ENABLED=false

# 数据种子初始化开关
CAMPUS_SEED_ENABLED=false
CAMPUS_SEED_SCALE=small
CAMPUS_SEED_RESET=true

# -----------------------------------------------------------------------------
# Feed + Search + Cache 配置
# -----------------------------------------------------------------------------
CAMPUS_FEED_PUSH_FOLLOWER_THRESHOLD=2000
CAMPUS_FEED_HOT_SHARD_COUNT=8
CAMPUS_SEARCH_PROVIDER=db
ELASTICSEARCH_URIS=http://127.0.0.1:9200
CAMPUS_CACHE_DEFAULT_TTL_SECONDS=300
CAMPUS_CACHE_NULL_TTL_SECONDS=45
